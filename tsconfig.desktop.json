{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2020"],
    "outDir": "./dist/desktop",
    "rootDir": "./src/desktop",
    "skipLibCheck": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmitOnError": false
  },
  "include": ["src/desktop/main/main.ts"],
  "exclude": ["node_modules", "dist"]
}
