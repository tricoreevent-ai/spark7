# Git Scripts Folder - .gitignore

# NEVER COMMIT THESE FILES

## Environment & Credentials
.env
.env.local
.env.*.local
.env.secret

## API Keys & Tokens
*.key
*.pem
*.pub
*.p12
*.pfx
credentials.json
access_token
refresh_token

## Private Data
config.json
secrets.json
passwords.txt
auth.json

## System Files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.backup

## Logs
*.log
logs/
debug.log

## Node/JavaScript
node_modules/
package-lock.json
yarn.lock
dist/
build/

## Database
*.db
*.sqlite
*.sqlite3
database.json

## OS Specific
.vscode/settings.json
.idea/
.project
*.iml
.classpath
.c9/

## Temporary Files
*.tmp
*.temp
.temp/
tmp/

## IDE Caches
.vscode/extensions
.vscode/settings
*.suo
*.user

## Git
.git/
.github/

## Archives
*.zip
*.rar
*.7z
*.tar.gz

## Dependencies (if scripts directory)
node_modules/
venv/
__pycache__/

## Custom Secrets
MY_SECRETS.txt
PRIVATE_KEYS.txt
CREDENTIALS.txt
TOKENS.json
API_KEYS.json

# ============================================
# SAFE TO COMMIT (Script files)
# ============================================
# *.bat
# *.ps1
# *.md
# .gitignore
# README.txt
