# Server Configuration
PORT=3000
NODE_ENV=development
SERVE_CLIENT=true
# For separate frontend hosting, set SERVE_CLIENT=false and allow frontend domain(s) below.
CORS_ORIGIN=http://localhost:5173,https://your-frontend-domain.com
# MongoDB Atlas Connection
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/databasename?retryWrites=true&w=majority
# For local MongoDB, use: mongodb://localhost:27017/sarva
AUTO_DB_BACKUP_ON_START=true
DB_BACKUP_DIR=backups
AUTO_DB_BASELINE_INIT=true

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRE=7d

# Company onboarding screen (public create-company screen on login page)
# Keep false in production unless you intentionally want company self-onboarding.
ENABLE_COMPANY_CREATION_SCREEN=false
# Optional shared key required by /api/auth/company-creation when onboarding is enabled.
COMPANY_CREATION_ACCESS_KEY=0075

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_TO_RECIPIENTS=admin@example.com
SMTP_APP_NAME=Tricore
SMTP_SECURE=false

# Payment Gateway
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# GST Configuration
GSTIN=your-gstin-number

# Client Configuration
# Keep client variables in .env.client

# Membership Reminder Webhooks (optional; keep empty to use mock/no-op delivery)
MEMBERSHIP_SMS_WEBHOOK_URL=
MEMBERSHIP_EMAIL_WEBHOOK_URL=
MEMBERSHIP_WHATSAPP_WEBHOOK_URL=

# Electron Configuration
ELECTRON_DEV=true
